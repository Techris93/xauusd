TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
TWELVE_DATA_SYMBOL=XAU/USD
PREDICTOR_INTERVAL=1h
PREDICTOR_PERIOD=5d
PREDICTION_REFRESH_SECONDS=5
# Legacy alias for compatibility. If present, this is interpreted as seconds.
PREDICTION_REFRESH_MINUTES=
TZ=UTC
WEB_PUSH_SUBJECT=mailto:alerts@example.com
# Optional but recommended for stable subscriptions across redeploys.
# If omitted, the app generates runtime VAPID keys automatically.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# Legacy gold-predictor names are also accepted.
VAPID_CLAIMS_SUBJECT=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional: point this at a mounted persistent disk path on Render.
WEB_PUSH_SUBSCRIPTIONS_PATH=
